{
  "description": "omnitsg",
  "keywords": [
    "i13n"
  ],
  "author": "Hill <hill@kimo.com>",
  "license": "MIT",
  "dependencies": {
    "css-query-selector": "*",
    "exec-script": "*",
    "i13n": "*",
    "i13n-client": "*",
    "object-nested": "*",
    "parse-ini-string": "*",
    "seturl": "*"
  },
  "devDependencies": {
    "babel-cli": "*",
    "btoa-atob": "0.1.2",
    "reshow-app": "*"
  },
  "scripts": {
    "clean": "find ./build ./assets -name '*.*' | xargs rm -rf",
    "build:cjs": "BABEL_ENV=build babel src -d build/cjs/src",
    "build:es": "BABEL_ENV=es babel src -d build/es/src",
    "build": "npm run clean && npm run build:cjs && npm run build:es",
    "prepublishOnly": "npm run build"
  }
}
