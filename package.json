{
  "description": "omnitag",
  "keywords": [
    "i13n"
  ],
  "author": "Hill <hill@kimo.com>",
  "license": "MIT",
  "dependencies": {
    "call-func": "*",
    "css-query-selector": "*",
    "exec-script": "*",
    "i13n": "*",
    "i13n-client": "*",
    "object-nested": "*",
    "parse-ini-string": "*",
    "seturl": "*",
    "win-doc": "*"
  },
  "devDependencies": {
    "btoa-atob": "0.1.2",
    "get-content": "1.0.2",
    "glob": "7.1.3",
    "reshow-app": "^0.13.0-beta"
  },
  "scripts": {
    "start": "ws -p 7000 --http2 --https -v",
    "clean": "find ./build ./assets -name '*.*' | xargs rm -rf",
    "build:cjs": "BABEL_ENV=test babel src -d build/cjs/src",
    "build:es": "BABEL_ENV=es babel src -d build/es/src",
    "build": "npm run clean && npm run build:cjs && npm run build:es",
    "mocha": "mocha 'build/cjs/**/__tests__/*.js' -r jsdom-global/register",
    "test": "npm run build:cjs && npm run mocha",
    "prepublishOnly": "npm run test && npm run build"
  }
}
