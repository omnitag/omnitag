{
  "description": "omnitag",
  "keywords": [
    "i13n"
  ],
  "author": "Hill <hill@kimo.com>",
  "license": "MIT",
  "dependencies": {
    "css-query-selector": "*",
    "exec-script": "*",
    "i13n": "*",
    "i13n-client": "*",
    "object-nested": "*",
    "parse-ini-string": "*",
    "seturl": "*"
  },
  "devDependencies": {
    "btoa-atob": "0.1.2",
    "get-content": "1.0.2",
    "glob": "7.1.3",
    "reshow-app": "*"
  },
  "scripts": {
    "clean": "find ./build ./assets -name '*.*' | xargs rm -rf",
    "build:cjs": "BABEL_ENV=test babel src -d build/cjs/src",
    "build:es": "BABEL_ENV=es babel src -d build/es/src",
    "build:test": "BABEL_ENV=test babel tests -d build/tests",
    "build": "npm run clean && npm run build:cjs && npm run build:es",
    "test": "npm run build && npm run build:test && mocha 'build/tests/**/*.js' -r jsdom-global/register",
    "prepublishOnly": "npm run build"
  }
}
